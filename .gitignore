# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# docs/ = memoria operativa del equipo (runbooks, ADRs, specs con refs/URLs
# internos). Se mantiene fuera del repo a propósito; vive en disco/OneDrive.
/docs/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment files. Lovable maneja el .env del repo (hoy solo claves públicas:
# anon key + URL). Se ignora para no commitear secretos reales por accidente a futuro.
.env
.env.*
!.env.example

# Lockfiles: el repo se estandariza en Bun (bun.lock). npm queda fuera para no
# tener dos gestores en paralelo. Una instalación local con npm no ensucia el repo.
package-lock.json

# Supabase CLI: estado local del link al proyecto (project-ref, pooler-url,
# versiones de CLI/gotrue/postgres). Lo genera la CLI, no es código del proyecto.
supabase/.temp/
